PORT=4000
DATABASE_PATH=./data/maldongmu.db

# OpenRouter (필수)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=google/gemini-2.5-flash

# 인증
JWT_SECRET=change-me
GUEST_CONVERSATION_LIMIT=3
GUEST_MESSAGE_LIMIT=3
ADMIN_PASSWORD=change-me

# URL (배포 시 실제 도메인으로 변경)
CORS_ORIGINS=http://localhost:3000
SERVER_PUBLIC_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# 구글 OAuth — https://console.cloud.google.com/apis/credentials
# 승인된 리디렉션 URI: {SERVER_PUBLIC_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 카카오 OAuth — https://developers.kakao.com (내 애플리케이션 > 앱 키 > REST API 키)
# Redirect URI 등록: {SERVER_PUBLIC_URL}/api/auth/kakao/callback
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
